// ============================================================================
//  FH6Auto 配置字段说明（config.example.json）
// ----------------------------------------------------------------------------
//  ⚠️⚠️⚠️ 重要：本文件仅供「对照参考」，含 // 注释，不是合法 JSON。
//  千万不要把它直接改名/复制成 config.json！
//  程序用标准 json.load 读取 config.json，遇到 // 注释会判定「配置损坏」，
//  并自动把你的整套配置重置为默认值（方案、次数、分享码全部丢失）。
//
//  正确用法：
//   1) 想改配置 → 直接在程序界面里改，或编辑「干净的」config.json（不含注释）。
//   2) 想知道某个字段什么意思 → 看本文件的行内注释，或 README 的字段表。
//
//  说明：config.json 由程序在每次改动界面控件时自动重写，
//  顶层字段与 schemes[当前方案] 会自动互相同步，带「自动同步」标注的无需手改。
// ============================================================================
{
    // 当前使用的方案索引（从 0 开始：0=方案1，1=方案2）
    "current_scheme": 0,

    // 方案列表。每个方案独立保存次数/技能树/筛选等，切方案时互不干扰
    "schemes": [
        {
            // 方案名称（仅显示用）
            "name": "方案1 - 无通行证用Revuelto刷超抽",
            // 本方案的车辆等级图标模板（方案1=S2，方案2=S1）
            "class_image": "classS2829.png",
            // 本方案【1.循环跑图】执行局数
            "race_count": 99,
            // 本方案【2.批量买车】执行次数
            "buy_count": 30,
            // 本方案【3.超级抽奖】执行次数
            "cj_count": 30,
            // 本方案【4.移除车辆】执行次数
            "sell_count": 30,
            // 本方案技能树点击顺序（up/down/left/right，按顺序依次点）
            "skill_dirs": ["up", "up", "up", "right", "right"],
            // 本方案跑图用的蓝图数字代码
            "share_code": "167982162",
            // 本方案超级抽奖模式：1=从我的车辆开始，2=从设计与喷涂开始
            "cj_mode": 2,
            // 本方案【1.循环跑图】跑完后是否继续下一阶段
            "chk_1": true,
            // 本方案【2.批量买车】跑完后是否继续下一阶段
            "chk_2": true,
            // 本方案【3.超级抽奖】跑完后是否继续下一阶段
            "chk_3": true,
            // 本方案【4.移除车辆】跑完后是否继续下一阶段
            "chk_4": true,
            // 【1.循环跑图】继续时跳转到的阶段号（1跑图/2买车/3超抽/4删车）
            "next_1": 2,
            // 【2.批量买车】继续时跳转到的阶段号
            "next_2": 3,
            // 【3.超级抽奖】继续时跳转到的阶段号
            "next_3": 4,
            // 【4.移除车辆】继续时跳转到的阶段号（填 1~3 跳回前序阶段，填 4 或更大则继续删车）
            "next_4": 1,
            // 删车筛选选项（OCR 视觉导航目标，必须与游戏筛选面板里的文字一致）
            "sell_filter": ["重复项", "S2", "顶级超跑", "全轮驱动"],
            // 跑图筛选选项（OCR 视觉导航目标，必须与游戏筛选面板里的文字一致）
            "race_filter": ["收藏", "复古拉力赛车", "传奇"]
        },
        {
            "name": "方案2 - （需要有通行证）Mad Mike 马自达超抽",
            "class_image": "classS1702.png",
            "race_count": 99,
            "buy_count": 45,
            "cj_count": 45,
            "sell_count": 45,
            "skill_dirs": ["right", "right", "up", "up", "up"],
            "share_code": "167982162",
            "cj_mode": 2,
            "chk_1": true,
            "chk_2": true,
            "chk_3": true,
            "chk_4": true,
            "next_1": 2,
            "next_2": 3,
            "next_3": 4,
            "next_4": 1,
            "sell_filter": ["S1", "漂移赛车", "后轮驱动", "传奇"],
            "race_filter": ["收藏", "复古拉力赛车", "传奇"]
        }
    ],

    // ====== 以下为顶层字段，与 schemes[当前方案] 自动同步，一般无需手改 ======

    // 当前方案的车辆等级图标模板（自动同步，勿手改）
    "class_image": "classS2829.png",
    // 当前方案【1.循环跑图】局数（自动同步）
    "race_count": 99,
    // 当前方案【2.批量买车】次数（自动同步）
    "buy_count": 30,
    // 当前方案【3.超级抽奖】次数（自动同步）
    "cj_count": 30,
    // 当前方案【1.循环跑图】跑完是否继续（自动同步）
    "chk_1": true,
    // 当前方案【2.批量买车】跑完是否继续（自动同步）
    "chk_2": true,
    // 当前方案【3.超级抽奖】跑完是否继续（自动同步）
    "chk_3": true,
    // 当前方案【4.移除车辆】跑完是否继续（自动同步）
    "chk_4": true,
    // 【1.循环跑图】继续时跳转的阶段号（自动同步）
    "next_1": 2,
    // 【2.批量买车】继续时跳转的阶段号（自动同步）
    "next_2": 3,
    // 【3.超级抽奖】继续时跳转的阶段号（自动同步）
    "next_3": 4,
    // 【4.移除车辆】继续时跳转的阶段号（自动同步；填 1~3 跳回前序，≥4 继续删车）
    "next_4": 1,
    // 全局循环次数（整个流程跑多少轮）
    "global_loops": 10,
    // 当前方案技能树点击顺序（自动同步）
    "skill_dirs": ["up", "up", "up", "right", "right"],
    // 当前方案蓝图数字代码（自动同步）
    "share_code": "167982162",
    // 游戏掉线/崩溃时是否自动重启游戏
    "auto_restart": false,
    // 自动重启游戏用的命令（默认 Steam 协议拉起 FH6）
    "restart_cmd": "start steam://run/2483190",
    // 单局跑图超时检测（秒），超时判定卡死并触发恢复
    "race_timeout": 600,
    // 每轮发车前等待时长（秒）：等游戏展示车辆+加载，默认 15，加载慢的机器可调大
    "race_start_wait": 15,
    // 卡死检测超时（秒，最小 10）
    "stuck_timeout": 60,
    // 调试截图开关：开启后保存识别截图到 debug/ 便于排查匹配问题
    "debug_screenshots": false,
    // 窗口焦点钩子：保持游戏窗口可被后台截图/发送按键
    "focus_hook_enabled": false,
    // 当前方案超级抽奖模式（自动同步）：1=从我的车辆，2=从设计与喷涂
    "cj_mode": 2,
    // 全部任务完成后是否自动关闭游戏
    "auto_close_game": false,
    // 全部任务完成后是否自动关机
    "auto_shutdown": false,
    // 诊断模式：输出更详细的诊断追踪日志
    "diagnostic_mode": false,
    // 当前方案【4.移除车辆】次数（自动同步）
    "sell_count": 30,
    // DirectML 加速 OCR（占用少量显存，加快识别）
    "use_directml": true,
    // 输入分享码前的等待秒数（仅 Xbox 版生效，默认 10）
    "sharecode_timeout": 10,
    // 当前方案名称（自动同步，勿手改）
    "name": "方案1 - 无通行证用Revuelto刷超抽"
}
